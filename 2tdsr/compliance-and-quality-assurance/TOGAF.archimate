  <folder name="Technology &amp; Physical" id="id-2dfe8019d2a749d384df265a5fb64e25" type="technology"/>
  <folder name="Motivation" id="id-5b15975874a64d71b777be04c3288b79" type="motivation">
    <element xsi:type="archimate:Stakeholder" name="Dono da softwarehouse" id="id-3dac7bd2f01244f19bc0c513b64688bc"/>
    <element xsi:type="archimate:Driver" name="Tem que haver um sistema informatizado para controlar o atendimento do suporte técnico ao cliente" id="id-b6d5c03e724741ba9039d97728591564"/>
    <element xsi:type="archimate:Assessment" name="Visualizar os chamados registrados e o seu andamento" id="id-282535161f13451e9a0ee024fca5dd61"/>
    <element xsi:type="archimate:Assessment" name="Confirmar a satisfação do cliente da empresa com o atendimento" id="id-668e762d345646a2af3d181c5ac235fa"/>
    <element xsi:type="archimate:Goal" name="Registrar os pedidos de suporte, permitindo a solução" id="id-e795b2cc96ee40379eb0071389ce0bb2"/>
    <element xsi:type="archimate:Goal" name="Guardar informações sobre soluções encontradas para problemas" id="id-a943738df81e4242b792251f14708ebb"/>
    <element xsi:type="archimate:Goal" name="Providenciar avaliação do cliente sobre o atendimento " id="id-bb5c5ddc939f4b1b88b10ff595dde545"/>
    <element xsi:type="archimate:Goal" name="Mensurar o tempo de atendimento " id="id-ebfbae3707a44280b41d47ec6cd3fccb"/>
    <element xsi:type="archimate:Principle" name="100% dos chamados e suas movimentações até a solução, documentados no software" id="id-234dfcbb222f449587019e1ef05cc3e2"/>
    <element xsi:type="archimate:Principle" name="A avaliação pelo cliente é uma opção e não uma obrigação" id="id-0a36d1dc3ce340a680707021efff936b"/>
    <element xsi:type="archimate:Principle" name="Todo chamado terá um tipo que determina um prazo máximo de solução, o qual, se excedido, implica no envio do chamado para o gerente de suporte" id="id-145b28e09eb14f07b857ce98888f54d3"/>
    <element xsi:type="archimate:Requirement" name="Registrar chamado " id="id-701620c6c0bd44d199b14df7f161325c"/>
    <element xsi:type="archimate:Requirement" name="Consultar base de soluções conhecidas para um problema" id="id-57c572edf6cd4174be2a5274ffabbb96"/>
    <element xsi:type="archimate:Requirement" name="Transferir chamado para outro técnico" id="id-c69845fa78ad44a88ea916c816506216"/>
    <element xsi:type="archimate:Requirement" name="Registrar a solução do chamado" id="id-24c95dff4b544169817faa82f484d3d4"/>
    <element xsi:type="archimate:Requirement" name="Avaliar atendimento" id="id-8a1cf50750204abbb4fe674048f75347"/>
    <element xsi:type="archimate:Requirement" name="Cadastrar as metas de atendimento" id="id-c51a45f523034a82a564bbc092ec2813"/>
    <element xsi:type="archimate:Requirement" name="Escalar chamado para o gerente" id="id-e68b155748234e82b34381f758e11a5d"/>
    <element xsi:type="archimate:Constraint" name="Registrar ID do cliente, telefone e email de contato, descrição do problema enfrentado, data e hora do acionamento, ID do atendente, número de protocolo de atendimento" id="id-c87b944498144e0693daef1dac790838"/>
    <element xsi:type="archimate:Constraint" name="Com base na descrição do problema, recuperar uma lista de possíveis soluções catalogadas" id="id-7c2579280eb4438eb9c747ed725a1dea"/>
    <element xsi:type="archimate:Constraint" name="Informar o ID do atendente de origem e o ID do destinatário, registrando também a data e hora do movimento (LOG)" id="id-ae24022d5e494e38b487678f28f077fa"/>
    <element xsi:type="archimate:Constraint" name="Descrever a solução, registrando data e hora da solução/problema na base de soluções conhecidas" id="id-61d7d095c1ac471592dfc350e36ba9e8"/>
    <element xsi:type="archimate:Constraint" name="O cliente deve atribuir 0-insatisfeito; 1-satisfeito" id="id-e2db8b33a2994aee96cb239c60462063"/>
    <element xsi:type="archimate:Constraint" name="Informar para cada tipo de chamado (Hardware, Aplicação, Banco de Dados, Redes, Controle de Acesso), apontar no número máximo de horas para solucionar" id="id-0f7a0a4370e543308848a1f0b67d94c7"/>
    <element xsi:type="archimate:Constraint" name="Se tempo de solução exceder o limite estabelecido para o tipo do chamado, ele é encaminhado para o ID do gerente, gerando um LOG com a data e hora do movimento" id="id-350dc708222a4d4cac69218dfb0aad0f"/>
    <element xsi:type="archimate:Value" name="Value" id="id-75f6fb3187264b20b0c9c4d9691953de"/>
  </folder>
